{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rocode.dev/schemas/scheduler-profile.schema.json",
  "title": "ROCode Scheduler Profile Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "string"
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "orchestrator": {
          "type": "string",
          "enum": [
            "sisyphus",
            "prometheus",
            "atlas",
            "hephaestus",
            "verifier"
          ],
          "description": "Supported presets are sisyphus, prometheus, atlas, hephaestus, and verifier."
        },
        "description": {
          "type": "string"
        },
        "model": {
          "$ref": "#/$defs/modelRef"
        },
        "skillList": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stages": {
          "type": "array",
          "description": "Ordered stage sequence. Each entry is either a plain stage-kind string or an object with per-stage overrides.",
          "items": {
            "$ref": "#/$defs/stageEntry"
          }
        },
        "agentTree": {
          "$ref": "#/$defs/agentTreeRef"
        },
        "skillGraph": {
          "$ref": "#/$defs/skillGraph"
        },
        "skillTree": {
          "$ref": "#/$defs/skillTree"
        },
        "workflow": {
          "$ref": "#/$defs/workflowRef",
          "description": "Inline iterative workflow config or a relative file path string."
        },
        "workflowPath": {
          "type": "string",
          "description": "Relative file path to an external iterative workflow JSON/JSONC file."
        },
        "iterativeWorkflow": {
          "$ref": "#/$defs/workflowRef",
          "description": "Alias of workflow. Accepts an inline iterative workflow object or a relative file path string."
        }
      }
    },
    "stageEntry": {
      "description": "Either a plain stage-kind string (\"plan\") or an object with per-stage overrides ({ \"kind\": \"plan\", \"toolPolicy\": \"allow-all\" }).",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "request-analysis",
            "route",
            "interview",
            "plan",
            "delegation",
            "review",
            "execution-orchestration",
            "handoff",
            "synthesis"
          ]
        },
        {
          "$ref": "#/$defs/stageOverride"
        }
      ]
    },
    "stageOverride": {
      "type": "object",
      "description": "Per-stage policy override. Only 'kind' is required; omitted fields fall through to preset defaults.",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "request-analysis",
            "route",
            "interview",
            "plan",
            "delegation",
            "review",
            "execution-orchestration",
            "handoff",
            "synthesis"
          ]
        },
        "toolPolicy": {
          "type": "string",
          "enum": ["allow-all", "allow-read-only", "disable-all"],
          "description": "Tool access policy for this stage. Overrides the preset default."
        },
        "loopBudget": {
          "type": "string",
          "description": "Loop budget for this stage. Either 'unbounded' or 'step-limit:N' (e.g. 'step-limit:5').",
          "pattern": "^(unbounded|step-limit:[1-9][0-9]*)$"
        },
        "sessionProjection": {
          "type": "string",
          "enum": ["hidden", "transcript"],
          "description": "Whether stage output is visible in the transcript."
        },
        "childSession": {
          "type": "boolean",
          "description": "Whether this stage creates an isolated attached session."
        },
        "agentTree": {
          "$ref": "#/$defs/agentTreeRef",
          "description": "Per-stage agent tree. Overrides the profile-level agentTree for this stage only. Can be an inline object or a file path string."
        },
        "agents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Agent name filter for this stage."
        },
        "skillList": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Skills available to this stage."
        }
      }
    },
    "modelRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerId", "modelId"],
      "properties": {
        "providerId": {
          "type": "string"
        },
        "modelId": {
          "type": "string"
        }
      }
    },
    "agentDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "systemPrompt": {
          "type": "string"
        },
        "maxSteps": {
          "type": "integer",
          "minimum": 1
        },
        "temperature": {
          "type": "number"
        },
        "allowedTools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "model": {
          "$ref": "#/$defs/modelRef"
        }
      }
    },
    "agentTreeRef": {
      "description": "An agent tree definition: either an inline agentTreeNode object or a relative file path string pointing to an external JSON/JSONC file containing an agentTreeNode.",
      "oneOf": [
        {
          "$ref": "#/$defs/agentTreeNode"
        },
        {
          "type": "string",
          "description": "Relative file path to an external agent tree JSON/JSONC file (resolved relative to this config file)."
        }
      ]
    },
    "agentTreeNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent"],
      "properties": {
        "agent": {
          "$ref": "#/$defs/agentDescriptor"
        },
        "prompt": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/agentTreeNode"
          }
        }
      }
    },
    "skillGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entryNodeId", "nodes"],
      "properties": {
        "entryNodeId": {
          "type": "string"
        },
        "maxHops": {
          "type": "integer",
          "minimum": 1
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/skillGraphNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/skillGraphEdge"
          }
        }
      }
    },
    "skillGraphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "agent"],
      "properties": {
        "id": {
          "type": "string"
        },
        "agent": {
          "$ref": "#/$defs/agentDescriptor"
        },
        "prompt": {
          "type": "string"
        }
      }
    },
    "skillGraphEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "condition": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["always"]
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "outputContains": {
                  "type": "string"
                },
                "outputNotContains": {
                  "type": "string"
                }
              },
              "minProperties": 1,
              "maxProperties": 1
            }
          ]
        }
      }
    },
    "skillTree": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contextMarkdown"],
      "properties": {
        "contextMarkdown": {
          "type": "string"
        },
        "tokenBudget": {
          "type": "integer",
          "minimum": 0
        },
        "truncationStrategy": {
          "type": "string",
          "enum": [
            "head",
            "tail",
            "head-tail"
          ]
        }
      }
    },
    "workflowRef": {
      "oneOf": [
        {
          "$ref": "#/$defs/iterativeWorkflowConfig"
        },
        {
          "type": "string",
          "description": "Relative file path to an external iterative workflow JSON/JSONC file."
        }
      ]
    },
    "iterativeWorkflowConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow"],
      "properties": {
        "workflow": {
          "$ref": "#/$defs/workflowDescriptor"
        },
        "objective": {
          "$ref": "#/$defs/workflowObjective"
        },
        "iterationPolicy": {
          "$ref": "#/$defs/iterationPolicy"
        },
        "decisionPolicy": {
          "$ref": "#/$defs/decisionPolicy"
        },
        "workspacePolicy": {
          "$ref": "#/$defs/workspacePolicy"
        },
        "artifacts": {
          "$ref": "#/$defs/workflowArtifacts"
        },
        "approvalPolicy": {
          "$ref": "#/$defs/approvalPolicy"
        },
        "fix": {
          "$ref": "#/$defs/fixConfig"
        },
        "debug": {
          "$ref": "#/$defs/debugConfig"
        },
        "security": {
          "$ref": "#/$defs/securityConfig"
        },
        "ship": {
          "$ref": "#/$defs/shipConfig"
        },
        "verifier": {
          "$ref": "#/$defs/verifierConfig"
        }
      }
    },
    "workflowDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "mode"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["autoresearch"]
        },
        "mode": {
          "type": "string",
          "enum": ["run", "plan", "security", "debug", "fix", "verify", "ship"]
        }
      }
    },
    "workflowObjective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "scope", "direction", "metric", "verify"],
      "properties": {
        "goal": {
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/workflowScope"
        },
        "direction": {
          "type": "string",
          "enum": ["higher-is-better", "lower-is-better"]
        },
        "metric": {
          "$ref": "#/$defs/workflowMetric"
        },
        "verify": {
          "$ref": "#/$defs/workflowCommand"
        },
        "guard": {
          "$ref": "#/$defs/workflowCommand"
        },
        "satisfiedWhen": {
          "$ref": "#/$defs/satisfiedWhen"
        }
      }
    },
    "workflowScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["include"],
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "workflowMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["numeric-extract", "count-lines", "exit-code", "json-path"]
        },
        "pattern": {
          "type": "string"
        },
        "countPattern": {
          "type": "string"
        },
        "jsonPath": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        }
      }
    },
    "workflowCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "workingDirectory": {
          "type": "string"
        }
      }
    },
    "satisfiedWhen": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metricAtLeast": {
          "type": "number"
        },
        "metricAtMost": {
          "type": "number"
        },
        "metricEquals": {
          "type": "number"
        }
      }
    },
    "iterationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["bounded", "unbounded"]
        },
        "maxIterations": {
          "type": "integer",
          "minimum": 1
        },
        "stopConditions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "objective-satisfied",
              "no-progress",
              "error-count-zero",
              "max-iterations-reached"
            ]
          }
        },
        "stuckThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "progressReportEvery": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "decisionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baselineStrategy": {
          "type": "string",
          "enum": ["capture-before-first-iteration", "from-config", "from-last-run"]
        },
        "baselineValue": {
          "type": "number"
        },
        "keepConditions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "metric-improved",
              "metric-unchanged-but-simpler",
              "verify-passed",
              "guard-passed"
            ]
          }
        },
        "discardConditions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["metric-regressed", "metric-unchanged", "verify-failed"]
          }
        },
        "reworkPolicy": {
          "$ref": "#/$defs/attemptPolicy"
        },
        "crashRetryPolicy": {
          "$ref": "#/$defs/attemptPolicy"
        },
        "simplicityOverride": {
          "$ref": "#/$defs/simplicityOverride"
        }
      }
    },
    "attemptPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "simplicityOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minImprovementPercent": {
          "type": "number"
        }
      }
    },
    "workspacePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshotStrategy"],
      "properties": {
        "mutationMode": {
          "type": "string",
          "enum": ["tracked", "untracked"]
        },
        "protectedPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "snapshotStrategy": {
          "type": "string",
          "enum": [
            "git-branch-per-iteration",
            "git-stash-stack",
            "patch-file",
            "worktree-fork"
          ]
        },
        "commitPolicy": {
          "$ref": "#/$defs/commitPolicy"
        }
      }
    },
    "commitPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commitKeptIterations": {
          "type": "boolean"
        },
        "messageTemplate": {
          "type": "string"
        },
        "squashOnCompletion": {
          "type": "boolean"
        }
      }
    },
    "workflowArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rootDir": {
          "type": "string"
        },
        "runDir": {
          "type": "string"
        },
        "iterationLog": {
          "$ref": "#/$defs/artifactFile"
        },
        "summary": {
          "$ref": "#/$defs/artifactFile"
        }
      }
    },
    "artifactFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        }
      }
    },
    "approvalPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requireHumanApprovalFor": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ship-action",
              "rollback-action",
              "external-write",
              "destructive-refactor"
            ]
          }
        },
        "allowAutoApproveWhen": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "dry-run-passed",
              "no-blockers",
              "all-guards-passed",
              "metric-threshold-met"
            ]
          }
        }
      }
    },
    "securityConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coverageTargets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["owasp-top10", "stride", "supply-chain", "cwe-top25"]
          }
        },
        "failOnSeverity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "diffMode": {
          "type": "boolean"
        },
        "autoFix": {
          "type": "boolean"
        },
        "requiredEvidence": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "file-line",
              "attack-scenario",
              "severity-justification",
              "cwe-id"
            ]
          }
        }
      }
    },
    "debugConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symptom"],
      "properties": {
        "symptom": {
          "type": "string"
        },
        "reproCommand": {
          "$ref": "#/$defs/workflowCommand"
        },
        "minSeverity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "requiredEvidence": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["file-line", "repro-steps", "hypothesis-log", "stack-trace"]
          }
        },
        "maxHypotheses": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "fixConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string",
          "enum": ["auto-detect", "explicit"]
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["test", "type", "lint", "build", "runtime"]
          }
        },
        "fromDebug": {
          "type": "boolean"
        },
        "debugRunRef": {
          "type": "string"
        },
        "stopOnZero": {
          "type": "boolean"
        }
      }
    },
    "verifierConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "criteria"],
      "properties": {
        "model": {
          "$ref": "#/$defs/modelRef"
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/verifierCriterion"
          }
        },
        "granularity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "repetitions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "selection": {
          "type": "string",
          "enum": ["round-robin", "tournament"]
        },
        "maxCandidates": {
          "type": "integer",
          "minimum": 2,
          "maximum": 12
        },
        "useLogprobs": {
          "type": "boolean"
        },
        "traceFormat": {
          "type": "string",
          "enum": ["compact", "full"]
        }
      }
    },
    "verifierCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "aggregation": {
          "type": "string",
          "enum": ["winner-vote", "score-margin"]
        }
      }
    },
    "shipConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["deployment", "release", "publish", "migration"]
        },
        "dryRun": {
          "type": "boolean"
        },
        "autoApprove": {
          "type": "boolean"
        },
        "rollbackEnabled": {
          "type": "boolean"
        },
        "monitorDurationMs": {
          "type": "integer",
          "minimum": 1
        },
        "monitorCommand": {
          "$ref": "#/$defs/workflowCommand"
        }
      }
    }
  }
}
