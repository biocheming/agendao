{
  "name": "agendao-web",
  "private": true,
  "version": "2026.6.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:generated": "node scripts/generated-artifacts.mjs",
    "generate:context-pressure": "node scripts/generate-context-pressure.mjs",
    "generate:context-closure": "node scripts/generate-context-closure.mjs",
    "check:generated": "node scripts/generated-artifacts.mjs --check",
    "lint": "npm run lint:eslint && npm run lint:oxlint",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx}\" --cache --cache-location .cache/eslint",
    "lint:oxlint": "oxlint --config .oxlintrc.json --react-plugin --promise-plugin --vitest-plugin src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live-transcript-state": "node scripts/test-live-transcript-state.mjs",
    "test:permission-interaction": "node scripts/test-permission-interaction.mjs",
    "test:session-insights-governance": "node scripts/test-session-insights-governance.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run check:generated && npm run typecheck && vite build",
    "preview": "vite preview",
    "smoke:phase4": "node scripts/phase4-smoke.mjs"
  },
  "dependencies": {
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.6.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.68.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
